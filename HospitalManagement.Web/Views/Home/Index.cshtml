@model HospitalManagement.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

@if (User.Identity.IsAuthenticated)
{
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    <h2 class="card-title">Welcome to Hospital Management System</h2>
                    <p class="card-text">
                        This is a comprehensive system for managing hospital operations including patient records, 
                        appointments, medical records, prescriptions, billing, and more.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Patients</h5>
                    <p class="card-text display-4">@Model.TotalPatients</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Doctors</h5>
                    <p class="card-text display-4">@Model.TotalDoctors</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Appointments</h5>
                    <p class="card-text display-4">@Model.TotalAppointments</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark">
                <div class="card-body">
                    <h5 class="card-title">Today's Appointments</h5>
                    <p class="card-text display-4">@Model.TodayAppointments</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">Recent Appointments</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Patient</th>
                                    <th>Doctor</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var appointment in Model.RecentAppointments)
                                {
                                    <tr>
                                        <td>@appointment.PatientName</td>
                                        <td>@appointment.DoctorName</td>
                                        <td>@appointment.AppointmentDate.ToShortDateString()</td>
                                        <td>
                                            @if (appointment.Status == "Scheduled")
                                            {
                                                <span class="badge bg-primary">@appointment.Status</span>
                                            }
                                            else if (appointment.Status == "Completed")
                                            {
                                                <span class="badge bg-success">@appointment.Status</span>
                                            }
                                            else if (appointment.Status == "Cancelled")
                                            {
                                                <span class="badge bg-danger">@appointment.Status</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@appointment.Status</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">Revenue Overview</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-title">Total Revenue</h6>
                                    <p class="card-text text-success fw-bold">$@Model.TotalRevenue.ToString("N2")</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-title">Monthly Revenue</h6>
                                    <p class="card-text text-success fw-bold">$@Model.MonthlyRevenue.ToString("N2")</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <canvas id="revenueChart" width="400" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">Appointments by Department</h5>
                </div>
                <div class="card-body">
                    <canvas id="departmentChart" width="400" height="200"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">Patients by Gender</h5>
                </div>
                <div class="card-body">
                    <canvas id="genderChart" width="400" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                // Revenue Chart
                var revenueCtx = document.getElementById('revenueChart').getContext('2d');
                var revenueData = @Html.Raw(Json.Serialize(Model.RevenueByMonth));
                var months = Object.keys(revenueData);
                var revenues = Object.values(revenueData);

                new Chart(revenueCtx, {
                    type: 'line',
                    data: {
                        labels: months,
                        datasets: [{
                            label: 'Monthly Revenue',
                            data: revenues,
                            backgroundColor: 'rgba(75, 192, 192, 0.2)',
                            borderColor: 'rgba(75, 192, 192, 1)',
                            borderWidth: 2,
                            tension: 0.1
                        }]
                    },
                    options: {
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function(value) {
                                        return '$' + value;
                                    }
                                }
                            }
                        }
                    }
                });

                // Department Chart
                var deptCtx = document.getElementById('departmentChart').getContext('2d');
                var deptData = @Html.Raw(Json.Serialize(Model.AppointmentsByDepartment));
                var departments = Object.keys(deptData);
                var appointmentCounts = Object.values(deptData);

                new Chart(deptCtx, {
                    type: 'bar',
                    data: {
                        labels: departments,
                        datasets: [{
                            label: 'Appointments',
                            data: appointmentCounts,
                            backgroundColor: [
                                'rgba(255, 99, 132, 0.5)',
                                'rgba(54, 162, 235, 0.5)',
                                'rgba(255, 206, 86, 0.5)',
                                'rgba(75, 192, 192, 0.5)',
                                'rgba(153, 102, 255, 0.5)'
                            ],
                            borderColor: [
                                'rgba(255, 99, 132, 1)',
                                'rgba(54, 162, 235, 1)',
                                'rgba(255, 206, 86, 1)',
                                'rgba(75, 192, 192, 1)',
                                'rgba(153, 102, 255, 1)'
                            ],
                            borderWidth: 1
                        }]
                    },
                    options: {
                        scales: {
                            y: {
                                beginAtZero: true
                            }
                        }
                    }
                });

                // Gender Chart
                var genderCtx = document.getElementById('genderChart').getContext('2d');
                var genderData = @Html.Raw(Json.Serialize(Model.PatientsByGender));
                var genders = Object.keys(genderData);
                var patientCounts = Object.values(genderData);

                new Chart(genderCtx, {
                    type: 'pie',
                    data: {
                        labels: genders,
                        datasets: [{
                            data: patientCounts,
                            backgroundColor: [
                                'rgba(54, 162, 235, 0.5)',
                                'rgba(255, 99, 132, 0.5)',
                                'rgba(255, 206, 86, 0.5)'
                            ],
                            borderColor: [
                                'rgba(54, 162, 235, 1)',
                                'rgba(255, 99, 132, 1)',
                                'rgba(255, 206, 86, 1)'
                            ],
                            borderWidth: 1
                        }]
                    }
                });
            });
        </script>
    }
}
else
{
    <div class="text-center">
        <h1 class="display-4">Welcome to Hospital Management System</h1>
        <p>A comprehensive solution for managing hospital operations.</p>
        <div class="row mt-5">
            <div class="col-md-4">
                <div class="card mb-4">
                    <div class="card-body text-center">
                        <i class="bi bi-person-plus-fill text-primary" style="font-size: 3rem;"></i>
                        <h5 class="card-title mt-3">Patient Management</h5>
                        <p class="card-text">Efficiently manage patient records, appointments, and medical history.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card mb-4">
                    <div class="card-body text-center">
                        <i class="bi bi-clipboard2-pulse-fill text-success" style="font-size: 3rem;"></i>
                        <h5 class="card-title mt-3">Medical Records</h5>
                        <p class="card-text">Maintain comprehensive medical records, prescriptions, and test results.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card mb-4">
                    <div class="card-body text-center">
                        <i class="bi bi-cash-coin text-warning" style="font-size: 3rem;"></i>
                        <h5 class="card-title mt-3">Billing & Insurance</h5>
                        <p class="card-text">Streamline billing processes and insurance claim management.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="mt-4">
            <a asp-area="" asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg me-2">Login</a>
            <a asp-area="" asp-controller="Account" asp-action="Register" class="btn btn-outline-primary btn-lg">Register</a>
        </div>
    </div>
}
